<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>BedLink | Spitalbettenvermittlung</title>
  <meta name="description" content="Enterprise PWA für Spitalbetten, Statusverwaltung und Reservierungen mit Supabase." />
  <meta name="theme-color" content="#0b2230" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="BedLink" />
  <link rel="manifest" href="manifest.json" />
  <link rel="apple-touch-icon" href="icons/icon-192.png" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div id="toast" class="toast hidden" role="status" aria-live="polite"></div>

  <div class="app-shell">
    <header class="topbar glass">
      <a class="brand" href="#dashboard" aria-label="BedLink Dashboard">
        <span class="brand-mark" aria-hidden="true">+</span>
        <span>
          <strong>BedLink</strong>
          <small>Spitalbettenvermittlung</small>
        </span>
      </a>
      <nav class="top-nav" aria-label="Hauptnavigation">
        <button class="nav-link active" data-tab="dashboard" type="button">Dashboard</button>
        <button class="nav-link" data-tab="beds" type="button">Betten</button>
        <button class="nav-link" data-tab="requests" type="button">Anfragen</button>
        <button class="nav-link" data-tab="admin" type="button">Setup</button>
      </nav>
      <div class="top-actions">
        <span id="connectionBadge" class="connection-badge">Demo lokal</span>
        <button id="themeToggle" class="icon-btn" type="button" aria-label="Theme wechseln">◐</button>
        <button id="syncButton" class="pill ghost" type="button">Sync</button>
        <button id="loginButton" class="pill primary" type="button">Login</button>
      </div>
    </header>

    <main class="main-grid">
      <section class="workspace">
        <section id="screen-dashboard" class="screen active" data-screen="dashboard">
          <div class="hero-card glass">
            <div class="hero-copy">
              <p class="eyebrow">Live-Kapazitäten & Disposition</p>
              <h1>Betten erfassen, Status steuern, Reservierungen sauber koordinieren.</h1>
              <p>Eine ruhige, professionelle Plattform für Akutbetten mit Fachbereich, Eigenschaften, Match-Logik und Supabase-Backend.</p>
              <div class="hero-actions">
                <button id="createBedHero" class="pill primary large" type="button">+ Bett erfassen</button>
                <button id="createRequestHero" class="pill secondary large" type="button">+ Anfrage erstellen</button>
              </div>
            </div>
            <div class="hero-status" aria-label="Aktuelle Lage">
              <span class="pulse-dot"></span>
              <strong id="heroFreeBeds">–</strong>
              <small>freie operative Betten</small>
            </div>
          </div>

          <section class="kpi-grid" aria-label="Kennzahlen">
            <article class="metric-card glass">
              <span class="metric-icon">▣</span>
              <div><span class="metric-label">Freie Betten</span><strong id="kpiAvailable">0</strong><small id="kpiAvailableHint">operativ erfasst</small></div>
            </article>
            <article class="metric-card glass">
              <span class="metric-icon">⌁</span>
              <div><span class="metric-label">Reserviert</span><strong id="kpiReserved">0</strong><small>wartet auf Eintritt</small></div>
            </article>
            <article class="metric-card glass">
              <span class="metric-icon">◴</span>
              <div><span class="metric-label">Offene Anfragen</span><strong id="kpiRequests">0</strong><small>noch nicht zugeteilt</small></div>
            </article>
            <article class="metric-card glass">
              <span class="metric-icon">↗</span>
              <div><span class="metric-label">Kapazität</span><strong id="kpiCapacity">0</strong><small>Stammdaten gesamt</small></div>
            </article>
          </section>

          <section class="panel glass">
            <div class="panel-head">
              <div>
                <p class="eyebrow">Spitäler</p>
                <h2>Kapazitäten und aktuelle Lage</h2>
              </div>
              <div class="segmented" role="group" aria-label="Fachbereich Schnellfilter">
                <button class="segment active" data-department-filter="all" type="button">Alle</button>
                <button class="segment" data-department-filter="Innere Medizin" type="button">Innere</button>
                <button class="segment" data-department-filter="Chirurgie" type="button">Chirurgie</button>
                <button class="segment" data-department-filter="Intensivpflege" type="button">IPS</button>
                <button class="segment" data-department-filter="Telemetrie" type="button">Telemetrie</button>
              </div>
            </div>
            <div id="hospitalList" class="hospital-list" aria-live="polite"></div>
          </section>

          <section class="panel glass">
            <div class="panel-head">
              <div>
                <p class="eyebrow">Match Engine</p>
                <h2>Offene Anfragen mit passenden Betten</h2>
              </div>
              <button id="createRequestPanel" class="pill secondary" type="button">Anfrage erstellen</button>
            </div>
            <div id="matchBoard" class="match-board"></div>
          </section>
        </section>

        <section id="screen-beds" class="screen" data-screen="beds">
          <div class="screen-head glass">
            <div>
              <p class="eyebrow">Bettinventar</p>
              <h1>Bettenstatus & Eigenschaften</h1>
              <p>Erfasse Betten, ordne Fachbereiche zu und pflege den operativen Status ohne doppelte Datenquellen.</p>
            </div>
            <button id="createBedButton" class="pill primary" type="button">+ Bett erfassen</button>
          </div>
          <div id="bedCards" class="bed-grid" aria-live="polite"></div>
        </section>

        <section id="screen-requests" class="screen" data-screen="requests">
          <div class="screen-head glass">
            <div>
              <p class="eyebrow">Offene Anfragen & Matches</p>
              <h1>Reservierungen koordinieren</h1>
              <p>Priorisieren, matchen, reservieren und nach Aufnahme abschliessen.</p>
            </div>
            <button id="createRequestButton" class="pill primary" type="button">+ Anfrage erstellen</button>
          </div>
          <div id="requestList" class="request-list" aria-live="polite"></div>
        </section>

        <section id="screen-admin" class="screen" data-screen="admin">
          <div class="screen-head glass">
            <div>
              <p class="eyebrow">Supabase Setup</p>
              <h1>SQL, Auth und GitHub Pages</h1>
              <p>Alles Notwendige liegt im ZIP. Das SQL kann direkt in Supabase ausgeführt werden.</p>
            </div>
            <button id="copySqlButton" class="pill primary" type="button">SQL kopieren</button>
          </div>
          <div class="setup-grid">
            <article class="panel glass setup-card">
              <h2>Schritte</h2>
              <ol class="setup-steps">
                <li><strong>Supabase SQL Editor:</strong> Datei <code>supabase.sql</code> vollständig ausführen.</li>
                <li><strong>Auth:</strong> Email/Password aktivieren und einen internen User anlegen.</li>
                <li><strong>Config:</strong> <code>supabase-config.js</code> prüfen oder mit neuem Projekt ersetzen.</li>
                <li><strong>Lokal testen:</strong> <code>python3 -m http.server 8080</code> starten und öffnen.</li>
                <li><strong>GitHub Pages:</strong> Dateien ins Repo laden, Pages auf Branch/root setzen.</li>
              </ol>
            </article>
            <article class="panel glass setup-card">
              <h2>Datenmodell</h2>
              <p>Stammdaten für 14 genannte Standorte, operative Betten, Reservierungen, Audit Log und eine transaktionale RPC-Funktion gegen Doppelreservationen.</p>
              <div class="schema-chips">
                <span>hospitals</span><span>hospital_beds</span><span>bed_reservations</span><span>bed_activity_log</span><span>reserve_bed_for_request()</span>
              </div>
            </article>
          </div>
          <pre id="sqlPreview" class="sql-preview" tabindex="0">SQL wird geladen…</pre>
        </section>
      </section>

      <aside class="side-panel glass" aria-label="Filter und Aktivität">
        <div class="side-section">
          <div class="section-head compact">
            <h2>Filter Optionen</h2>
            <button id="resetFiltersButton" class="text-btn" type="button">Reset</button>
          </div>
          <label class="field"><span>Spital</span><select id="hospitalFilter"></select></label>
          <label class="field"><span>Fachbereich</span><select id="departmentFilter"></select></label>
          <label class="field"><span>Status</span><select id="statusFilter"></select></label>
          <label class="field"><span>Eigenschaft</span><select id="featureFilter"></select></label>
          <label class="field"><span>Suche</span><input id="searchInput" type="search" placeholder="Bett, Station, Zimmer…" /></label>
        </div>

        <div class="side-section">
          <div class="section-head compact">
            <h2>Schnellaktionen</h2>
          </div>
          <button id="quickFreeBeds" class="quick-action" type="button"><span>Freie Betten zeigen</span><strong id="quickFreeCount">0</strong></button>
          <button id="quickUrgentRequests" class="quick-action" type="button"><span>Dringende Anfragen</span><strong id="quickUrgentCount">0</strong></button>
          <button id="quickCleaning" class="quick-action" type="button"><span>Reinigung / blockiert</span><strong id="quickCleaningCount">0</strong></button>
        </div>

        <div class="side-section">
          <div class="section-head compact">
            <h2>Aktivität</h2>
            <span class="muted">Live</span>
          </div>
          <div id="activityFeed" class="activity-feed"></div>
        </div>
      </aside>
    </main>
  </div>

  <dialog id="bedDialog" class="modal">
    <form id="bedForm" method="dialog" class="modal-card">
      <input type="hidden" id="bedId" />
      <div class="modal-head">
        <div><p class="eyebrow">Bettprofil</p><h2 id="bedDialogTitle">Bett erfassen</h2></div>
        <button class="icon-btn" value="cancel" type="button" data-close-dialog aria-label="Schliessen">×</button>
      </div>
      <div class="form-grid">
        <label class="field"><span>Spital</span><select id="bedHospital" required></select></label>
        <label class="field"><span>Bett-ID / Code</span><input id="bedCode" required placeholder="z.B. LUZ-IM-024" /></label>
        <label class="field"><span>Fachbereich</span><select id="bedDepartment" required></select></label>
        <label class="field"><span>Pflegestufe</span><select id="bedCareLevel" required></select></label>
        <label class="field"><span>Status</span><select id="bedStatus" required></select></label>
        <label class="field"><span>Station</span><input id="bedWard" placeholder="z.B. Station A5" /></label>
        <label class="field"><span>Zimmer</span><input id="bedRoom" placeholder="z.B. 501" /></label>
        <label class="field"><span>Reserviert bis</span><input id="bedReservedUntil" type="datetime-local" /></label>
      </div>
      <fieldset class="feature-box">
        <legend>Eigenschaften</legend>
        <div id="bedFeatureChecks" class="feature-checks"></div>
      </fieldset>
      <label class="field"><span>Patientenreferenz / Notiz</span><textarea id="bedNotes" rows="3" placeholder="Keine Patientendaten im Klartext speichern; nur interne Referenzen."></textarea></label>
      <div class="modal-actions">
        <button class="pill ghost" type="button" data-close-dialog>Abbrechen</button>
        <button class="pill primary" type="submit">Speichern</button>
      </div>
    </form>
  </dialog>

  <dialog id="requestDialog" class="modal">
    <form id="requestForm" method="dialog" class="modal-card">
      <input type="hidden" id="requestId" />
      <div class="modal-head">
        <div><p class="eyebrow">Anfrage</p><h2 id="requestDialogTitle">Anfrage erstellen</h2></div>
        <button class="icon-btn" value="cancel" type="button" data-close-dialog aria-label="Schliessen">×</button>
      </div>
      <div class="form-grid">
        <label class="field"><span>Zielspital optional</span><select id="requestHospital"></select></label>
        <label class="field"><span>Fachbereich</span><select id="requestDepartment" required></select></label>
        <label class="field"><span>Priorität</span><select id="requestPriority" required></select></label>
        <label class="field"><span>Anfragende Stelle</span><input id="requesterName" required placeholder="z.B. Notfall Luzern" /></label>
        <label class="field"><span>Kontakt</span><input id="requesterContact" placeholder="Telefon / E-Mail" /></label>
        <label class="field"><span>Patientenreferenz</span><input id="patientReference" placeholder="z.B. Fall-ID 42" /></label>
        <label class="field"><span>Start</span><input id="requestStartsAt" type="datetime-local" required /></label>
        <label class="field"><span>Ende optional</span><input id="requestEndsAt" type="datetime-local" /></label>
      </div>
      <fieldset class="feature-box">
        <legend>Benötigte Eigenschaften</legend>
        <div id="requestFeatureChecks" class="feature-checks"></div>
      </fieldset>
      <label class="field"><span>Notizen</span><textarea id="requestNotes" rows="3" placeholder="Medizinisch notwendige Angaben knapp, keine unnötigen Personendaten."></textarea></label>
      <div class="modal-actions">
        <button class="pill ghost" type="button" data-close-dialog>Abbrechen</button>
        <button class="pill primary" type="submit">Anfrage speichern</button>
      </div>
    </form>
  </dialog>

  <dialog id="authDialog" class="modal">
    <form id="authForm" method="dialog" class="modal-card narrow">
      <div class="modal-head">
        <div><p class="eyebrow">Supabase Auth</p><h2>Einloggen</h2></div>
        <button class="icon-btn" value="cancel" type="button" data-close-dialog aria-label="Schliessen">×</button>
      </div>
      <p class="muted">Ohne Login läuft die App im lokalen Demo-Modus. Nach Login ist Supabase die Quelle der Wahrheit.</p>
      <label class="field"><span>E-Mail</span><input id="authEmail" type="email" autocomplete="email" required placeholder="name@spital.ch" /></label>
      <label class="field"><span>Passwort</span><input id="authPassword" type="password" autocomplete="current-password" required minlength="8" /></label>
      <div class="modal-actions split">
        <button id="resetPasswordButton" class="text-btn" type="button">Passwort zurücksetzen</button>
        <button class="pill primary" type="submit">Einloggen</button>
      </div>
    </form>
  </dialog>

  <script src="supabase-config.js"></script>
  <script src="supabase-schema.js"></script>
  <script async src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2" onload="window.dispatchEvent(new Event('supabase-sdk-loaded'))"></script>
  <script src="app.js" defer></script>
</body>
</html>
